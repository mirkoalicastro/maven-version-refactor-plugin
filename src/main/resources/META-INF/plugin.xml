<idea-plugin>
    <id>io.github.mirkoalicastro.mavenversionrefactor</id>
    <name>Maven Version Refactor</name>
    <version>1.0.7</version>
    <vendor email="mirkoalicastro@gmail.com" url="http://www.mirkoalicastro.com">Mirko Alicastro</vendor>

    <!-- Product and plugin compatibility requirements -->
    <!-- https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Add your extensions here -->
        <intentionAction order="first">
            <className>io.github.mirkoalicastro.mavenversionrefactor.MavenVersionRefactorAction</className>
        </intentionAction>
    </extensions>
</idea-plugin>
